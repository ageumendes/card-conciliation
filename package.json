{
  "name": "conciliação de cartões",
  "version": "0.0.19",
  "private": true,
  "description": "Backend NestJS para conciliacao de cartoes Sipag com Firebird",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:watch:cielo": "CIELO_EDI_WATCH_ENABLED=true npm run start:dev",
    "build": "tsc -p tsconfig.build.json",
    "test:reconciliation": "ts-node scripts/reconciliation.utils.test.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.4.21",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.4.21",
    "@nestjs/platform-express": "^10.4.21",
    "@nestjs/schedule": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "chokidar": "^3.6.0",
    "node-firebird": "^0.9.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "ssh2-sftp-client": "^11.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/multer": "^1.4.12",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
